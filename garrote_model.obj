# Fibre Glass Cable - Garrote Model
# Open in Blender: File > Import > Wavefront (.obj)
# Fine-tune, then export as FBX for Unity AssetBundle
#
# Layout: Left Handle (-X) --- Wire --- Right Handle (+X)
# Scale: meters (Unity scale)
# Total width: ~30cm (handles at ±15cm from center)

mtllib garrote_model.mtl

# ============================================================
# LEFT HANDLE (octagonal cylinder, 1.2cm diameter, 6cm tall)
# Centered at X=-0.15, pointing up along Y
# ============================================================
o LeftHandle

# Bottom ring (Y=-0.03)
v -0.156000  -0.030000  0.000000
v -0.154243  -0.030000  0.004243
v -0.150000  -0.030000  0.006000
v -0.145757  -0.030000  0.004243
v -0.144000  -0.030000  0.000000
v -0.145757  -0.030000 -0.004243
v -0.150000  -0.030000 -0.006000
v -0.154243  -0.030000 -0.004243

# Top ring (Y=0.03)
v -0.156000   0.030000  0.000000
v -0.154243   0.030000  0.004243
v -0.150000   0.030000  0.006000
v -0.145757   0.030000  0.004243
v -0.144000   0.030000  0.000000
v -0.145757   0.030000 -0.004243
v -0.150000   0.030000 -0.006000
v -0.154243   0.030000 -0.004243

# Bottom cap
f 1 2 3 4 5 6 7 8

# Top cap
f 16 15 14 13 12 11 10 9

# Side faces
f 1 9 10 2
f 2 10 11 3
f 3 11 12 4
f 4 12 13 5
f 5 13 14 6
f 6 14 15 7
f 7 15 16 8
f 8 16 9 1

# ============================================================
# RIGHT HANDLE (octagonal cylinder, same dimensions)
# Centered at X=+0.15
# ============================================================
o RightHandle

# Bottom ring (Y=-0.03)
v  0.144000  -0.030000  0.000000
v  0.145757  -0.030000  0.004243
v  0.150000  -0.030000  0.006000
v  0.154243  -0.030000  0.004243
v  0.156000  -0.030000  0.000000
v  0.154243  -0.030000 -0.004243
v  0.150000  -0.030000 -0.006000
v  0.145757  -0.030000 -0.004243

# Top ring (Y=0.03)
v  0.144000   0.030000  0.000000
v  0.145757   0.030000  0.004243
v  0.150000   0.030000  0.006000
v  0.154243   0.030000  0.004243
v  0.156000   0.030000  0.000000
v  0.154243   0.030000 -0.004243
v  0.150000   0.030000 -0.006000
v  0.145757   0.030000 -0.004243

# Bottom cap
f 17 18 19 20 21 22 23 24

# Top cap
f 32 31 30 29 28 27 26 25

# Side faces
f 17 25 26 18
f 18 26 27 19
f 19 27 28 20
f 20 28 29 21
f 21 29 30 22
f 22 30 31 23
f 23 31 32 24
f 24 32 25 17

# ============================================================
# WIRE (thin rectangular strip connecting handle tops)
# From left handle top center to right handle top center
# Thickness: 1.5mm, slight sag in the middle
# ============================================================
o Wire

# Left end (at left handle top)
v -0.150000   0.030000  0.00075
v -0.150000   0.030000 -0.00075
v -0.150000   0.03075   0.00075
v -0.150000   0.03075  -0.00075

# Middle (slight sag)
v  0.000000   0.020000  0.00075
v  0.000000   0.020000 -0.00075
v  0.000000   0.02075   0.00075
v  0.000000   0.02075  -0.00075

# Right end (at right handle top)
v  0.150000   0.030000  0.00075
v  0.150000   0.030000 -0.00075
v  0.150000   0.03075   0.00075
v  0.150000   0.03075  -0.00075

# Left segment faces
f 33 35 37 39
f 40 38 36 34
f 33 34 36 35
f 35 36 38 37
f 37 38 40 39
f 39 40 34 33

# Right segment faces
f 39 41 43 37
f 44 42 40 38
f 39 40 42 41
f 41 42 44 43
f 43 44 38 37
f 37 38 40 39
