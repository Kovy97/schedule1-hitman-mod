# Poison Syringe Model — Separated Parts with Materials
# Oriented along Z axis
mtllib syringe.mtl

# ============================================================
# PART 1: Glass Barrel (transparent, shows green liquid inside)
# ============================================================
o Glass_Barrel
usemtl Glass

# Bottom ring (z=0.5)
v  0.250  0.000  0.500
v  0.177  0.177  0.500
v  0.000  0.250  0.500
v -0.177  0.177  0.500
v -0.250  0.000  0.500
v -0.177 -0.177  0.500
