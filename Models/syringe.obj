v  0.177 -0.177  0.500

# Top ring (z=3.5)
v  0.250  0.000  3.500
v  0.177  0.177  3.500
v  0.000  0.250  3.500
v -0.177  0.177  3.500
v -0.250  0.000  3.500
v -0.177 -0.177  3.500
v  0.000 -0.250  3.500
v  0.177 -0.177  3.500

# Barrel side faces
f 1 2 10 9
f 2 3 11 10
f 3 4 12 11
f 4 5 13 12
f 5 6 14 13
f 6 7 15 14
f 7 8 16 15
f 8 1 9 16

# Bottom cap
f 8 7 6 5 4 3 2 1
# Top cap
f 9 10 11 12 13 14 15 16

# ============================================================
# PART 2: Poison Liquid (green, inside the barrel)
# ============================================================
o Poison_Liquid
usemtl Poison

# Liquid fills ~80% of barrel height (z=0.6 to z=2.9)
# Slightly smaller radius (0.22) so it sits inside the glass
